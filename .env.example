# Required — one BROWSERBASE_API_KEY_<NAME> per project.
# The <NAME> suffix becomes the project label in the UI dropdown.
# Add at least one key to get started.
BROWSERBASE_API_KEY_DEVELOPMENT=your_dev_api_key_here
# BROWSERBASE_API_KEY_PRODUCTION=your_prod_api_key_here
# BROWSERBASE_API_KEY_STAGE=your_stage_api_key_here

# Optional
# PORT=3002
# CORS_ORIGIN=http://localhost:5173
# BROWSERBASE_API_URL=https://api.browserbase.com/v1
